# Environment configuration for guard-glp.
# Copy to `.env` (gitignored) and edit:  cp .env.example .env
# Loaded automatically by the dataset scripts: the shell workers `source .env`,
# and the Python entry point calls `load_dotenv()`.

# HuggingFace + uv caches. Point these at the ACROSS-NODE SHARED filesystem (not
# per-node $SCRATCH) so model weights are downloaded once and reused by every
# SLURM node, instead of re-downloading per node.
HF_HOME=/path/to/shared/.cache/huggingface
UV_CACHE_DIR=/path/to/shared/.cache/uv

# Token for gated models (e.g. meta-llama/*) and pushing datasets to the Hub.
# Get one at https://huggingface.co/settings/tokens (also run `huggingface-cli login`
# and accept each gated model's license on the Hub).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
